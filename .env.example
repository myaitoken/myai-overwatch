# /opt/myai-overwatch/.env  (copy this, fill in secrets, chmod 600)

# Coordinator (internal AWS bridge address — no auth needed on same bridge)
COORDINATOR_URL=http://10.42.42.142:8000

# Infra-gateway (all recovery actions go through here)
GATEWAY_URL=https://gateway.infinihash.com
GATEWAY_TOKEN=   # from ~/Documents/Claude/Projects/MyAi/infra-gateway/bearer-token.txt

# Slack (uses gateway /slack/notify relay)
SLACK_CHANNEL=#myai-ops
# SLACK_TOKEN is read from Brain /root/.secrets/slack.env by the gateway relay;
# no need to put it here — GATEWAY_TOKEN is enough.

# MyAi coordinator auth (if coordinator requires API key)
MYAI_API_KEY=

# Tuning (defaults shown)
CHECK_INTERVAL=30
FAILURE_THRESH=2
RECOVERY_THRESH=2
RESTART_COOLDOWN=120
MAX_RESTARTS=3
RESTART_WINDOW=3600
HEARTBEAT_STALE=90

# Config paths
AGENTS_CONFIG=/opt/myai-overwatch/agents.yaml
STATE_FILE=/var/lib/myai-overwatch/state.json
